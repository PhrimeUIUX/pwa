{
  "version": 2,
  "builds": [
    { "src": "build/web/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/build/web/index.html"
    },
    {
      "source": "/:page",
      "destination": "/build/web/:page.html"
    },
    {
      "source": "/(.*)",
      "destination": "/build/web/$1"
    }
  ]
}
